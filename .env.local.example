# Integrity Sprint Log — Environment Config
# Copy this file to .env.local and fill in the values you need.
# Most settings can also be configured via the Setup Wizard (first run).

# ── OPTIONAL: Server-level OP fallback ──────────────────────────────────────
# If set, this is used as a fallback when a user has not configured their own token.
# Each user should set their own token via the Setup Wizard for proper KPI attribution.
OP_BASE_URL=
OP_PROJECT_ID=
OP_API_TOKEN=

# ── DATA DIRECTORY ────────────────────────────────────────────────────────────
# Absolute path to store session data, op-cache, and user-config.
# Defaults to the project root (process.cwd()) if not set.
# Example Windows: C:/Users/yourname/apps/daily-sprint-next
# Example Linux:   /opt/daily-sprint-next
CACHE_DATA_DIR=
SPRINT_OUTPUT_DIR=

# ── AI (optional server-level fallback) ──────────────────────────────────────
# Users can set their own AI provider keys via Settings.
# Only needed if you want a server-wide AI key as fallback.
ANTHROPIC_API_KEY=

# ── GOOGLE CALENDAR (optional) ───────────────────────────────────────────────
# For Sprint Review reminders from Google Calendar.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID with redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ── INTERNAL ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=isl-local-secret-change-this-in-prod
