# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# ISL runtime data (per-user, not committed)
google-token.json
google-profile.json
op-cache.json
op-config.json
op-mode.json
user-config.json
session-logs/
daily-sprints/

# Context and session draft files (runtime, not committed)
context-draft.json
context-drafts.json.bak
processed-sessions.json

# Log files
*.log
server.err
startup.log

# Personal task/memory data (per-user)
task-memory/
memory/

# Personal bat scripts with hardcoded paths/tokens
open-network-access.bat
start-isl.bat
rebuild-isl.bat

# Claude project files
CLAUDE.md

# pnpm (project uses npm)
pnpm-lock.yaml
pnpm-workspace.yaml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

data/
